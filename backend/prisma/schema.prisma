// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum TransactionCategory {
  FOOD_DRINK
  TRANSPORTATION
  GROCERIES
  SUBSCRIPTIONS
  ENTERTAINMENT
  SHOPPING
  HEALTH
  UTILITIES
  TRAVEL
  UNKNOWN
}

enum TransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum CorrectionField {
  MERCHANT
  CATEGORY
}

model User {
  id           String @id @default(uuid())
  email        String @unique
  passwordHash String

  role UserRole @default(USER)

  preferredCurrency String @default("USD")

  createdAt DateTime @default(now())

  transactions Transaction[]
  merchantPreferences UserMerchantPreference[]
  transactionCorrections TransactionCorrection[]
  smartRules SmartRule[]
  subscriptionInsights UserSubscriptionInsight[]

  //"In my code, I want to refer to this model as User, but in the actual database, the table is named users.
  @@map("users")
}

model Transaction {
  id String @id @default(uuid())

  userId String
  merchantId String?

  amount Decimal @db.Decimal(19, 4)

  currency String @default("USD")

  // parser certainty measurement
  // deciding follow-up questions
  // analytics quality
  // debugging parser accuracy
  // future AI tuning
  confidenceScore Float?

  // background workers
  // retries
  // queue       systems
  aiProcessed Boolean @default(false)

  processingStatus TransactionStatus @default(PENDING)

  // separates:
  // AI guess
  // user-approved financial truth
  isConfirmed Boolean @default(false)

  // identifies ingestion source
  // analytics
  // debugging
  // ingestion optimization
  sourceType String?

  // debugging
  // reparsing historical data
  // regression analysis
  parserVersion String?

  // preserves original user input EXACTLY
  // debugging
  // reparsing
  // auditability
  // future AI improvements
  descriptionRaw String

  // cleaned/preprocessed version
  // regex matching
  // search
  // analytics
  // merchant detection
  descriptionNormalized String?

  // canonical merchant identity
  // merchant analytics
  // recurring spending detection
  // categorization
  merchantName String?

  // semantic spending classification
  // dashboards
  // charts
  // summaries
  // insights
  category TransactionCategory @default(UNKNOWN)

  // parser-output snapshot preserved for learning/auditability
  parserAmount Decimal? @db.Decimal(19, 4)
  parserCurrency String?
  parserMerchantName String?
  parserCategory TransactionCategory?
  parserMissingFields String[] @default([])

  transactionDate DateTime

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id])
  merchant Merchant? @relation(fields: [merchantId], references: [id])
  corrections TransactionCorrection[]

  @@unique([id, userId])
  @@index([userId, transactionDate(sort: Desc)])
  @@index([userId, merchantId, transactionDate(sort: Desc)])
  @@index([merchantName])
  @@map("transactions")
}

model Merchant {
  id String @id @default(uuid())

  canonicalName String
  normalizedName String @unique

  categoryTendencies Json @default("{}")
  recurringLikelihood Float @default(0)
  transactionCount Int @default(0)
  confidence Float @default(0.5)
  metadata Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  aliases MerchantAlias[]
  transactions Transaction[]
  userPreferences UserMerchantPreference[]
  corrections TransactionCorrection[]
  smartRules SmartRule[]
  subscriptionInsights UserSubscriptionInsight[]

  @@index([canonicalName])
  @@index([recurringLikelihood])
  @@map("merchants")
}

model MerchantAlias {
  id String @id @default(uuid())

  merchantId String
  alias String
  normalizedAlias String @unique
  confidence Float @default(0.7)
  source String @default("SYSTEM")
  hitCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([normalizedAlias])
  @@map("merchant_aliases")
}

model UserMerchantPreference {
  id String @id @default(uuid())

  userId String
  merchantId String
  preferredCategory TransactionCategory
  confidence Float @default(0.5)
  correctionCount Int @default(1)
  lastCorrectedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@unique([userId, merchantId])
  @@index([userId, preferredCategory])
  @@map("user_merchant_preferences")
}

model TransactionCorrection {
  id String @id @default(uuid())

  userId String
  transactionId String?
  merchantId String?
  field CorrectionField

  parserMerchantName String?
  finalMerchantName String?
  parserCategory TransactionCategory?
  finalCategory TransactionCategory?
  confidenceBefore Float?
  source String @default("HUMAN_CONFIRMATION")
  metadata Json @default("{}")

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  merchant Merchant? @relation(fields: [merchantId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([merchantId, field])
  @@index([transactionId])
  @@map("transaction_corrections")
}

model SmartRule {
  id String @id @default(uuid())

  userId String
  merchantId String?
  merchantNamePattern String?
  normalizedMerchantName String?
  category TransactionCategory
  priority Int @default(100)
  isActive Boolean @default(true)
  confidence Float @default(1)
  metadata Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  merchant Merchant? @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([userId, isActive, priority])
  @@index([userId, normalizedMerchantName])
  @@map("smart_rules")
}

model UserSubscriptionInsight {
  id String @id @default(uuid())

  userId String
  merchantId String?
  merchantName String
  currency String
  estimatedMonthlyCost Decimal @db.Decimal(19, 4)
  nextExpectedCharge DateTime
  recurrenceConfidence Float
  cadenceDays Int
  transactionCount Int
  lastSeenAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  merchant Merchant? @relation(fields: [merchantId], references: [id], onDelete: SetNull)

  @@unique([userId, merchantId, currency])
  @@index([userId, recurrenceConfidence])
  @@index([userId, nextExpectedCharge])
  @@map("user_subscription_insights")
}
