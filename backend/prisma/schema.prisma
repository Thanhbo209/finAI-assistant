// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum TransactionCategory {
  FOOD_DRINK
  TRANSPORTATION
  GROCERIES
  SUBSCRIPTIONS
  ENTERTAINMENT
  SHOPPING
  HEALTH
  UTILITIES
  TRAVEL
  UNKNOWN
}

enum TransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id           String @id @default(uuid())
  email        String @unique
  passwordHash String

  role UserRole @default(USER)

  createdAt DateTime @default(now())

  transactions Transaction[]

  //"In my code, I want to refer to this model as User, but in the actual database, the table is named users.
  @@map("users")
}

model Transaction {
  id String @id @default(uuid())

  userId String

  amount Decimal @db.Decimal(19, 4)

  currency String @default("USD")

  // parser certainty measurement
  // deciding follow-up questions
  // analytics quality
  // debugging parser accuracy
  // future AI tuning
  confidenceScore Float?

  // background workers
  // retries
  // queue       systems
  aiProcessed Boolean @default(false)

  processingStatus TransactionStatus @default(PENDING)

  // separates:
  // AI guess
  // user-approved financial truth
  isConfirmed Boolean @default(false)

  // identifies ingestion source
  // analytics
  // debugging
  // ingestion optimization
  sourceType String?

  // debugging
  // reparsing historical data
  // regression analysis
  parserVersion String?

  // preserves original user input EXACTLY
  // debugging
  // reparsing
  // auditability
  // future AI improvements
  descriptionRaw String

  // cleaned/preprocessed version
  // regex matching
  // search
  // analytics
  // merchant detection
  descriptionNormalized String?

  // canonical merchant identity
  // merchant analytics
  // recurring spending detection
  // categorization
  merchantName String?

  // semantic spending classification
  // dashboards
  // charts
  // summaries
  // insights
  category TransactionCategory @default(UNKNOWN)

  transactionDate DateTime

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id])

  @@unique([id, userId])
  @@index([userId, transactionDate(sort: Desc)])
  @@index([merchantName])
  @@map("transactions")
}
